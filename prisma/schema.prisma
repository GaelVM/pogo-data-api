generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MoveCategory {
  FAST
  CHARGED
  UNKNOWN
}

enum MoveAvailability {
  NORMAL
  ELITE
  LEGACY
  EVENT
}

model Pokemon {
  id            Int           @id
  slug          String        @unique @db.VarChar(120)
  name          String        @db.VarChar(120)
  generation    Int?
  generationName String?      @db.VarChar(80)
  familyId      Int?
  legendary     Boolean       @default(false)
  mythic        Boolean       @default(false)
  ultraBeast    Boolean       @default(false)
  forms         PokemonForm[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([name])
  @@index([generation])
}

model PokemonForm {
  id                BigInt          @id @default(autoincrement())
  pokemonId         Int
  formId            Int
  slug              String          @unique @db.VarChar(180)
  name              String          @db.VarChar(120)
  proto              String?         @db.VarChar(180)
  isDefault          Boolean         @default(false)
  isCostume          Boolean         @default(false)
  attack             Int?
  defense            Int?
  stamina            Int?
  height             Float?
  weight             Float?
  buddyDistance      Float?
  thirdMoveStardust  Int?
  thirdMoveCandy     Int?
  tradable           Boolean?
  transferable       Boolean?
  pokemon            Pokemon        @relation(fields: [pokemonId], references: [id], onDelete: Cascade)
  types              PokemonType[]
  moves              PokemonMove[]
  evolvesFrom        Evolution[]     @relation("EvolutionTo")
  evolvesTo          Evolution[]     @relation("EvolutionFrom")
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@unique([pokemonId, formId])
  @@index([pokemonId])
  @@index([attack])
}

model Type {
  id            Int           @id
  slug          String        @unique @db.VarChar(80)
  name          String        @db.VarChar(80)
  pokemon       PokemonType[]
  moves         Move[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model PokemonType {
  pokemonFormId BigInt
  typeId        Int
  slot          Int
  pokemonForm   PokemonForm @relation(fields: [pokemonFormId], references: [id], onDelete: Cascade)
  type          Type        @relation(fields: [typeId], references: [id], onDelete: Restrict)

  @@id([pokemonFormId, typeId])
  @@index([typeId])
}

model Move {
  id            Int              @id
  slug          String           @unique @db.VarChar(140)
  name          String           @db.VarChar(140)
  proto         String?          @db.VarChar(180)
  category      MoveCategory     @default(UNKNOWN)
  typeId        Int?
  power         Int?
  energy        Int?
  durationMs    Int?
  pvpPower      Int?
  pvpEnergy     Int?
  pvpTurns      Int?
  type          Type?            @relation(fields: [typeId], references: [id], onDelete: SetNull)
  pokemon       PokemonMove[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([name])
  @@index([typeId])
  @@index([category])
}

model PokemonMove {
  pokemonFormId BigInt
  moveId        Int
  availability  MoveAvailability @default(NORMAL)
  pokemonForm   PokemonForm      @relation(fields: [pokemonFormId], references: [id], onDelete: Cascade)
  move          Move             @relation(fields: [moveId], references: [id], onDelete: Cascade)

  @@id([pokemonFormId, moveId, availability])
  @@index([moveId])
}

model Evolution {
  id           BigInt      @id @default(autoincrement())
  fromFormId   BigInt
  toFormId     BigInt
  candyCost    Int?
  itemId       Int?
  fromForm     PokemonForm @relation("EvolutionFrom", fields: [fromFormId], references: [id], onDelete: Cascade)
  toForm       PokemonForm @relation("EvolutionTo", fields: [toFormId], references: [id], onDelete: Cascade)

  @@unique([fromFormId, toFormId])
  @@index([toFormId])
}

model DatasetVersion {
  id            String   @id @default(cuid())
  version       String   @unique @db.VarChar(80)
  source        String   @db.VarChar(180)
  sourceHash    String   @db.VarChar(64)
  pokemonCount  Int
  formCount     Int
  moveCount     Int
  importedAt    DateTime @default(now())
  active        Boolean  @default(false)

  @@index([active, importedAt])
}
